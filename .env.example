# nestjs-raw variant branch

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=research123
POSTGRES_DB=shop

# JWT (variant бүгд адил secret ашиглана)
JWT_SECRET=research-jwt-secret

# Backend implementation — R5 feature flag
#   alpha (default): vulnerable-by-design (SQLi f-string, BOLA no ownership, Overposting whitelist:false)
#   beta:            fixed guard
IMPLEMENTATION=alpha

# Datadog trial API key (`--profile datadog` идэвхтэй үед)
DD_API_KEY=
DD_SITE=datadoghq.com

# Frontend — docker-compose дотор `http://backend:3001` default.
# Deploy үед public URL-руу заана (Render, Fly.io гэх мэт).
NEXT_PUBLIC_API_BASE=http://backend:3001

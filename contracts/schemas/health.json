{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "health.json",
  "title": "HealthResponse",
  "type": "object",
  "required": ["status", "variant"],
  "properties": {
    "status": { "const": "ok" },
    "variant": {
      "type": "string",
      "enum": ["nestjs-raw", "nestjs-orm", "fiber-raw", "fiber-orm", "fastapi-raw", "fastapi-orm"]
    },
    "implementation": { "enum": ["alpha", "beta"] }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "products.json",
  "$defs": {
    "Product": {
      "type": "object",
      "required": ["id", "name", "price"],
      "properties": {
        "id":          { "type": "integer" },
        "name":        { "type": "string" },
        "description": { "type": ["string", "null"] },
        "price":       { "type": "number" },
        "category_id": { "type": ["integer", "null"] }
      },
      "additionalProperties": false
    },
    "ProductListResponse": {
      "type": "object",
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/Product" }
        }
      },
      "additionalProperties": false
    },
    "ProductResponse": {
      "type": "object",
      "required": ["product"],
      "properties": {
        "product": { "$ref": "#/$defs/Product" }
      },
      "additionalProperties": false
    }
  }
}

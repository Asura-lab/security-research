{
  "title": "security-research — 6 backend defensive capability",
  "description": "Халдлагын үеийн CPU/RAM/duration харьцуулалт. Variant + implementation tag-аар groupBy.",
  "widgets": [
    {
      "definition": {
        "title": "HTTP request duration p95 (ms)",
        "type": "timeseries",
        "requests": [
          {
            "q": "p95:http.request.duration{variant:*} by {variant,implementation}",
            "display_type": "line"
          }
        ]
      }
    },
    {
      "definition": {
        "title": "HTTP request count (rps)",
        "type": "timeseries",
        "requests": [
          {
            "q": "sum:http.request.count{variant:*}.as_rate() by {variant,implementation}",
            "display_type": "line"
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Container CPU %",
        "type": "timeseries",
        "requests": [
          {
            "q": "avg:docker.cpu.usage{container_name:security-research-*} by {container_name}",
            "display_type": "area"
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Container RAM (MB)",
        "type": "timeseries",
        "requests": [
          {
            "q": "avg:docker.mem.rss{container_name:security-research-*}/1000000 by {container_name}",
            "display_type": "line"
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Attack markers (event stream)",
        "type": "event_stream",
        "query": "tags:attack:*"
      }
    }
  ],
  "template_variables": [
    { "name": "variant", "prefix": "variant", "default": "*" },
    { "name": "implementation", "prefix": "implementation", "default": "*" }
  ],
  "layout_type": "ordered"
}

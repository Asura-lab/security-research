// Prisma schema — security-research 2/6 (NestJS + Prisma ORM).
//
// Эх сурвалж: `db/schema.sql`. Схемийг Prisma-ээр migrate хийхгүй, зөвхөн
// map хийж унших/бичих. Migration нь `db/schema.sql`-ийн үүрэг.
//
// Дүрэм: SQL-ийн talбарын нэрийг Prisma-ийн `@map` ашиглаж хэвээр үлдээнэ.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  username      String   @unique @db.VarChar(50)
  email         String   @unique @db.VarChar(255)
  passwordHash  String   @map("password_hash") @db.VarChar(255)
  role          String   @default("customer") @db.VarChar(20)
  isAdmin       Boolean  @default(false) @map("is_admin")
  address       String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  orders          Order[]
  secrets         Secret[]
  profileTargets  ProfileTarget[]

  @@map("users")
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @db.VarChar(100)
  products Product[]

  @@map("categories")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(200)
  description String?
  price       Decimal  @db.Decimal(10, 2)
  categoryId  Int?     @map("category_id")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  category Category?  @relation(fields: [categoryId], references: [id])
  items    OrderItem[]

  @@index([name], map: "idx_products_name")
  @@index([categoryId], map: "idx_products_category")
  @@map("products")
}

model Order {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  status    String   @default("pending") @db.VarChar(20)
  total     Decimal  @default(0) @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user        User          @relation(fields: [userId], references: [id])
  items       OrderItem[]
  targets     OrderTarget[]

  @@index([userId], map: "idx_orders_user")
  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int     @map("order_id")
  productId Int?    @map("product_id")
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Secret {
  id          Int      @id @default(autoincrement())
  ownerId     Int?     @map("owner_id")
  secretValue String   @map("secret_value") @db.VarChar(255)
  secretNonce String   @map("secret_nonce") @db.VarChar(64)
  secretLabel String   @map("secret_label") @db.VarChar(100)
  vector      String   @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  owner User? @relation(fields: [ownerId], references: [id])

  @@index([ownerId], map: "idx_secrets_owner")
  @@index([vector], map: "idx_secrets_vector")
  @@map("secrets")
}

model OrderTarget {
  id           Int      @id @default(autoincrement())
  orderId      Int      @map("order_id")
  targetValue  String   @map("target_value") @db.VarChar(255)
  targetNonce  String   @map("target_nonce") @db.VarChar(64)
  targetLabel  String   @map("target_label") @db.VarChar(100)
  vector       String   @db.VarChar(20)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamp(6)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId], map: "idx_order_targets_order")
  @@map("order_targets")
}

model ProfileTarget {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  targetValue  String   @map("target_value") @db.VarChar(255)
  targetNonce  String   @map("target_nonce") @db.VarChar(64)
  targetLabel  String   @map("target_label") @db.VarChar(100)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_profile_targets_user")
  @@map("profile_targets")
}

model TargetSnapshot {
  id           Int      @id @default(autoincrement())
  snapshotId   String   @map("snapshot_id") @db.VarChar(36)
  targetLabel  String   @map("target_label") @db.VarChar(100)
  valueBefore  String   @map("value_before") @db.VarChar(255)
  valueAfter   String?  @map("value_after") @db.VarChar(255)
  snapshotTs   DateTime @default(now()) @map("snapshot_ts") @db.Timestamp(6)

  @@index([snapshotId], map: "idx_target_snapshots_sid")
  @@index([targetLabel], map: "idx_target_snapshots_label")
  @@map("target_snapshots")
}
